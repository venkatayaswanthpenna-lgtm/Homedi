# App Settings
PORT=4000
NODE_ENV=development

# Security
JWT_SECRET=your_jwt_secret_key_here
BCRYPT_SALT_ROUNDS=10

# Database (PostgreSQL - Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://homedi_user:homedi_password@localhost:5432/homedi_db?schema=public"

# Database (MongoDB - Mongoose)
# Format: mongodb://USER:PASSWORD@HOST:PORT/DATABASE?authSource=admin
MONGODB_URI="mongodb://homedi_user:homedi_password@localhost:27017/homedi_db?authSource=admin"

# AI & Third Party (Placeholders)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
AWS_S3_BUCKET_NAME=homedi-medical-records
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
